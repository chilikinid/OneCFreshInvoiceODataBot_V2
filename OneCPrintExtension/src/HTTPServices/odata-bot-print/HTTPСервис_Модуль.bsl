// Модуль HTTP-сервиса odata-bot-print.
//
// HTTP-сервис:
//   Имя: odata-bot-print
//
// Шаблон URL:
//   Метод: POST
//   Шаблон: /print
//   Обработчик: Печать

Функция Печать(Запрос)

    Попытка
        ТелоЗапроса = Запрос.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);

        ЧтениеJSON = Новый ЧтениеJSON;
        ЧтениеJSON.УстановитьСтроку(ТелоЗапроса);
        Параметры = ПрочитатьJSON(ЧтениеJSON);
        ЧтениеJSON.Закрыть();

        EntitySet = ПолучитьПолеJSON(Параметры, "entitySet");
        RefKey = ПолучитьПолеJSON(Параметры, "refKey");
        PrintForm = ПолучитьПолеJSON(Параметры, "printForm");

        Если ПустаяСтрока(EntitySet) Или ПустаяСтрока(RefKey) Тогда
            Возврат ОтветJSON(400, "Не заполнены entitySet/refKey.");
        КонецЕсли;

        PDF = ODataBotПечатьСервер.СформироватьPDF(EntitySet, RefKey, PrintForm);

        Ответ = Новый HTTPСервисОтвет(200);
        Ответ.Заголовки.Вставить("Content-Type", "application/pdf");
        Ответ.Заголовки.Вставить("Content-Disposition", "attachment; filename=""print.pdf""");
        Ответ.УстановитьТелоИзДвоичныхДанных(PDF);
        Возврат Ответ;

    Исключение
        Возврат ОтветJSON(500, ОписаниеОшибки());
    КонецПопытки;

КонецФункции

Функция ПолучитьПолеJSON(СтруктураJSON, ИмяПоля)

    Если СтруктураJSON = Неопределено Тогда
        Возврат "";
    КонецЕсли;

    ЗначениеПоля = Неопределено;
    Если СтруктураJSON.Свойство(ИмяПоля, ЗначениеПоля) Тогда
        Возврат СокрЛП(Строка(ЗначениеПоля));
    КонецЕсли;

    Возврат "";

КонецФункции

Функция ОтветJSON(КодСостояния, Сообщение)

    Данные = Новый Структура;
    Данные.Вставить("error", Сообщение);

    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, Данные);
    ТелоОтвета = ЗаписьJSON.Закрыть();

    Ответ = Новый HTTPСервисОтвет(КодСостояния);
    Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(ТелоОтвета, КодировкаТекста.UTF8);
    Возврат Ответ;

КонецФункции
