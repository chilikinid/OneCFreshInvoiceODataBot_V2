Функция СформироватьPDF(EntitySet, RefKey, PrintForm = "") Экспорт

    СсылкаНаДокумент = ПолучитьСсылкуДокумента(EntitySet, RefKey);
    ТабличныйДокумент = СформироватьТабличныйДокумент(СсылкаНаДокумент, PrintForm);

    ИмяФайла = ПолучитьИмяВременногоФайла("pdf");

    Попытка
        ТабличныйДокумент.Записать(ИмяФайла, ТипФайлаТабличногоДокумента.PDF);
        Возврат Новый ДвоичныеДанные(ИмяФайла);
    Наконец
        УдалитьФайлы(ИмяФайла);
    КонецПопытки;

КонецФункции

Функция ПолучитьСсылкуДокумента(EntitySet, RefKey)

    УИД = Новый УникальныйИдентификатор(RefKey);

    Если EntitySet = "Document_СчетНаОплатуПокупателю" Тогда
        Возврат Документы.СчетНаОплатуПокупателю.ПолучитьСсылку(УИД);
    КонецЕсли;

    Если EntitySet = "Document_РеализацияТоваровУслуг" Тогда
        Возврат Документы.РеализацияТоваровУслуг.ПолучитьСсылку(УИД);
    КонецЕсли;

    Если EntitySet = "Document_СчетФактураВыданный" Тогда
        Возврат Документы.СчетФактураВыданный.ПолучитьСсылку(УИД);
    КонецЕсли;

    ВызватьИсключение "Неизвестный entitySet для печати: " + EntitySet;

КонецФункции

Функция СформироватьТабличныйДокумент(СсылкаНаДокумент, PrintForm)

    Если ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.СчетНаОплатуПокупателю") Тогда
        Возврат СформироватьСчетНаОплату(СсылкаНаДокумент, PrintForm);
    КонецЕсли;

    Если ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
        Возврат СформироватьРеализациюИлиУПД(СсылкаНаДокумент, PrintForm);
    КонецЕсли;

    Если ТипЗнч(СсылкаНаДокумент) = Тип("ДокументСсылка.СчетФактураВыданный") Тогда
        Возврат СформироватьСчетФактуруВыданный(СсылкаНаДокумент, PrintForm);
    КонецЕсли;

    ВызватьИсключение "Для документа не настроено формирование печатной формы: " + Строка(СсылкаНаДокумент);

КонецФункции

